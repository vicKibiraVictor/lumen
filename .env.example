# Copy to .env to override defaults (optional — sane defaults are built in).

# Database credentials (CHANGE THE PASSWORD for any real deployment)
POSTGRES_USER=lumen
POSTGRES_PASSWORD=lumen
POSTGRES_DB=lumen

# Host ports
WEB_PORT=3000
DB_PORT=5432

# Published image to build/push/deploy (used by compose and `make`)
WEB_IMAGE=youruser/lumen-web:latest
